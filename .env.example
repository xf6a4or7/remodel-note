# ===== 이 파일을 복사해서 .env 로 만들고 실제 값을 채우세요 =====
# cp .env.example .env
# .env 는 .gitignore 에 의해 깃에 올라가지 않습니다.

# ----- 네이버 클라우드 플랫폼 CLOVA Speech -----
# NCP 콘솔 > AI·Application Service > CLOVA Speech > 도메인 생성 후 발급
CLOVA_SPEECH_INVOKE_URL=https://clovaspeech-gw.ncloud.com/external/v1/XXXX/xxxxxxxx
CLOVA_SPEECH_SECRET=여기에_시크릿_키

# ----- Anthropic Claude API (분석/교정용) -----
ANTHROPIC_API_KEY=sk-ant-여기에_키

# ----- 사용할 STT 엔진 선택: clova | whisper -----
STT_ENGINE=clova

# ----- (선택) Whisper 로 교체 시 -----
# OPENAI_API_KEY=sk-여기에_키
